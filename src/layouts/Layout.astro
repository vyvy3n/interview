---
import '../styles/global.css';
const { title = 'interview cheat sheet', showHome = true } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f0f0f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <title>{title}</title>
  </head>
  <body>
    <a id="top" tabindex="-1"></a>
    {showHome && (
      <header class="site">
        <a href="/" class="home">← cheat sheet</a>
        <a href="/concepts/six-level-starter" class="quick">📋 template</a>
        <a href="/concepts/python-snippets" class="quick">🐍 snippets</a>
      </header>
    )}
    <main>
      <slot />
    </main>
    <a href="#top" class="back-to-top" aria-label="Back to top" title="Back to top">↑</a>
  </body>
</html>
