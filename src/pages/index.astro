  <script is:inline>
    (function () {
      var views = {
        debug: document.getElementById('view-debug'),
        general: document.getElementById('view-general'),
      };
      var buttons = document.querySelectorAll('.view-toggle button');
      function show(v) {
        if (!views[v]) v = 'debug';
        for (var k in views) views[k].hidden = (k !== v);
        buttons.forEach(function (b) {
          b.classList.toggle('active', b.dataset.view === v);
        });
        try { localStorage.setItem('cheatsheet-view', v); } catch (e) {}
        window.scrollTo(0, 0);
      }
      buttons.forEach(function (b) {
        b.addEventListener('click', function () { show(b.dataset.view); });
      });
      var saved;
      try { saved = localStorage.getItem('cheatsheet-view'); } catch (e) {}
      if (saved === 'general') show('general');  // default is debug
    })();
  </script>
