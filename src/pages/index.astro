      }
      buttons.forEach(function (b) {
        b.addEventListener('click', function () { show(b.dataset.view); });
      });
      var saved;
      try { saved = localStorage.getItem('cheatsheet-view'); } catch (e) {}
      if (saved === 'general') show('general');  // default is debug
    })();
  </script>
</Layout>

