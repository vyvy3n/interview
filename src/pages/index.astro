---
import Layout from '../layouts/Layout.astro';

const GH = 'https://github.com/vyvy3n/interview/blob/main/practice-general-coding-ability';
const GH_DEBUG = 'https://github.com/vyvy3n/interview/tree/main/practice-python-debugging';

// ── Debug mocks — the 6-rung difficulty ladder for Assessment 2 ──
const debugMocks = [
  { num: '1', dir: 'mock-1-eval-harness',   title: 'Eval Harness',    tier: 'onboarding',  bugs: 7, tag: 'sampling + stats' },
  { num: '2', dir: 'mock-2-token-analyzer', title: 'Token Analyzer',  tier: 'onboarding',  bugs: 6, tag: 'vocab + similarity' },
  { num: '3', dir: 'mock-3-gridworld',      title: 'Gridworld Bandit', tier: 'onboarding', bugs: 6, tag: 'bandit + DP' },
  { num: '4', dir: 'mock-4-bpe-tokenizer',  title: 'BPE Tokenizer',   tier: 'interview',   bugs: 7, tag: 'merges + encode/decode' },
  { num: '5', dir: 'mock-5-attention',      title: 'Attention',       tier: 'interview',   bugs: 7, tag: 'softmax + masking' },
  { num: '6', dir: 'mock-6-sampler',        title: 'Sampler / Decoder', tier: 'hardest',   bugs: 8, tag: 'temp + top-k/p + gen' },
];

// ── General coding (the previous home content) ──
const sixLevelProblems = [
  { num: '09', title: 'Task Scheduler',     dir: '09-concurrent-task-scheduler', tag: 'threading' },
  { num: '10', title: 'KV Store',           dir: '10-thread-safe-keyvalue',      tag: 'asyncio'   },
  { num: '11', title: 'Bank Account',       dir: '11-bank-account-system',       tag: 'threading' },
  { num: '12', title: 'File Cache Multi',   dir: '12-file-cache-multitenant',    tag: 'asyncio'   },
  { num: '13', title: 'LLM Conv Service',   dir: '13-llm-conversation-service',  tag: 'threading' },
  { num: '14', title: 'LLM API Gateway',    dir: '14-llm-api-gateway',           tag: 'asyncio'   },
  { num: '15', title: 'DNS Resolver ★',     dir: '15-dns-resolver',              tag: 'real OA'   },
];

const fourLevelProblems = [
  { num: '01', title: 'Bank Transactions',  dir: '01-bank-transactions',         tag: 'finance'  },
  { num: '02', title: 'In-Memory DB',       dir: '02-in-memory-db',              tag: 'KV+TTL'   },
  { num: '03', title: 'File System',        dir: '03-file-system',               tag: 'files'    },
  { num: '04', title: 'Cloud Storage',      dir: '04-cloud-storage',             tag: 'sharing'  },
  { num: '05', title: 'LLM Router',         dir: '05-llm-request-router',        tag: 'GPU'      },
  { num: '06', title: 'LLM Cache',          dir: '06-llm-prompt-cache',          tag: 'TTL+LRU'  },
  { num: '07', title: 'LLM Rate Limiter',   dir: '07-llm-rate-limiter',          tag: 'tokens'   },
  { num: '08', title: 'LLM Conv Manager',   dir: '08-llm-conversation-manager',  tag: 'context'  },
];

const fellowsPath = [
  { href: '/concepts/six-level-starter',     title: 'Six-Level Starter Template',     hint: 'paste-ready scaffold for L1-L6 (threading + asyncio variants)' },
  { href: '/concepts/python-snippets',       title: 'Python Snippets',                hint: 'lean one-liner reference: sort, dict, deque, threading, asyncio, heap' },
  { href: '/concepts/codesignal-archetypes', title: 'CodeSignal Archetypes',          hint: 'understand the 4/6-level dispatch shape — the actual test format' },
  { href: '/concepts/concurrency-models',    title: 'Concurrency: when to use what',  hint: 'asyncio vs threading vs multiprocessing decision matrix' },
  { href: '/concepts/concurrency-threading', title: 'threading deep-dive',            hint: 'Lock, Event, Condition, ThreadPoolExecutor' },
  { href: '/concepts/concurrency-asyncio',   title: 'asyncio deep-dive',              hint: 'async/await, gather, IsolatedAsyncioTestCase' },
  { href: '/concepts/codesignal',            title: 'CodeSignal & Pytest',            hint: 'how to run tests on the platform; debugging tips' },
];

const sections = [
  {
    title: 'Interview Workflow',
    note: 'how to actually run the tests during a coding round',
    items: [
      { href: '/concepts/codesignal',            title: 'CodeSignal & Pytest',       hint: 'ICF format, pytest commands, debugging' },
      { href: '/concepts/codesignal-archetypes', title: 'CodeSignal Archetypes',     hint: '4/6-level dispatch shape, 8 problem domains, in-repo practice' },
      { href: '/concepts/six-level-starter',     title: 'Six-Level Starter Template', hint: 'paste-ready Python scaffold + per-level decision crib + submit-often rule' },
      { href: '/concepts/python-snippets',       title: 'Python Snippets',           hint: 'lean one-liner reference: sort, dict, deque, threading, asyncio, heap' },
    ],
  },
  {
    title: 'Concurrency',
    note: 'required for Anthropic Fellows; both threading and asyncio',
    items: [
      { href: '/concepts/concurrency-models',    title: 'When to use what',          hint: 'asyncio vs threading vs multiprocessing decision matrix' },
      { href: '/concepts/concurrency-threading', title: 'threading',                 hint: 'Lock, Event, Condition, Semaphore, ThreadPoolExecutor' },
      { href: '/concepts/concurrency-asyncio',   title: 'asyncio',                   hint: 'async/await, gather, wait_for, Lock, IsolatedAsyncioTestCase' },
      { href: '/concepts/rate-limiter-patterns', title: 'Rate Limiter Patterns',     hint: 'token bucket, leaky, sliding window; per-tenant + thread-safe' },
    ],
  },
  {
    title: 'Pointers & Windows',
    note: 'scan an array with a moving window or two indices',
    items: [
      { href: '/concepts/two-pointers',          title: 'Two Pointers',              hint: 'opposite ends, fast/slow, partitioning' },
      { href: '/concepts/sliding-window',        title: 'Sliding Window',            hint: 'fixed/variable subarray under invariant' },
      { href: '/concepts/prefix-sum',            title: 'Prefix Sum',                hint: 'range sums, subarray-sum-equals-K' },
      { href: '/concepts/monotonic-stack',       title: 'Monotonic Stack',           hint: 'next greater/smaller, min stack' },
    ],
  },
  {
    title: 'Search & Selection',
    note: 'find or rank without sorting everything',
    items: [
      { href: '/concepts/binary-search',         title: 'Binary Search',             hint: 'sorted array or monotonic predicate' },
      { href: '/concepts/heap',                  title: 'Heap & Top-K',              hint: 'heapify O(n), kth element, streaming' },
      { href: '/concepts/quickselect',           title: 'QuickSelect',               hint: 'kth largest in O(n) avg, partition' },
    ],
  },
  {
    title: 'Trees & Graphs',
    note: 'traverse, explore, decompose',
    items: [
      { href: '/concepts/bfs',                   title: 'BFS',                       hint: 'layered, implicit graph, bidirectional' },
      { href: '/concepts/dfs-backtracking',      title: 'DFS & Backtracking',        hint: 'enumerate, prune, undo' },
      { href: '/concepts/tree-divide-conquer',   title: 'Tree Divide & Conquer',     hint: 'return-from-children pattern' },
      { href: '/concepts/topo-sort',             title: 'Topological Sort',          hint: 'DAG order, indegree BFS or DFS' },
      { href: '/concepts/union-find',            title: 'Union Find',                hint: 'connected components, path compression' },
    ],
  },
  {
    title: 'Greedy',
    items: [
      { href: '/concepts/greedy',                title: 'Greedy',                    hint: 'local choice → global optimum, intervals' },
    ],
  },
  {
    title: 'Dynamic Programming',
    note: 'start with Fundamentals; pick the topology that matches the problem',
    items: [
      { href: '/concepts/dp',                    title: 'DP Fundamentals',           hint: 'state · transition · order · 3 flavors' },
      { href: '/concepts/dp-sequence',           title: 'Sequence DP (1D)',          hint: 'house robber, decode ways, LIS, stocks' },
      { href: '/concepts/dp-grid',               title: 'Grid / Coordinate DP',      hint: 'unique paths, min path sum, max square' },
      { href: '/concepts/dp-knapsack',           title: 'Knapsack DP',               hint: '0/1, unbounded, count, partition' },
      { href: '/concepts/dp-interval',           title: 'Interval DP',               hint: 'palindromes, burst balloons, matrix chain' },
      { href: '/concepts/dp-two-sequence',       title: 'Two-Sequence DP',           hint: 'LCS, edit distance, regex match' },
    ],
  },
  {
    title: 'Data Structures',
    items: [
      { href: '/concepts/hash-table',            title: 'Hash Table Tricks',         hint: 'count, prefix-hash, two-sum family' },
      { href: '/concepts/trie',                  title: 'Trie / Prefix Tree',        hint: 'word search, prefix queries' },
      { href: '/concepts/linked-list',           title: 'Linked List',               hint: 'dummy head, doubly linked, reversal' },
      { href: '/concepts/segment-tree',          title: 'Segment Tree & BIT',        hint: 'range queries + updates in O(log n)' },
    ],
  },
  {
    title: 'Number & String Math',
    items: [
      { href: '/concepts/big-int-strings',       title: 'Big-Int String Math',       hint: 'add/subtract/multiply long numbers' },
      { href: '/concepts/fast-power',            title: 'Fast Power',                hint: 'a^n mod m in O(log n)' },
    ],
  },
  {
    title: 'Design',
    items: [
      { href: '/concepts/lru-cache',             title: 'LRU Cache',                 hint: 'hash + doubly linked list' },
      { href: '/concepts/bst-iterator',          title: 'BST Iterator',              hint: 'in-order traversal, controlled stack' },
      { href: '/concepts/state-serialization',   title: 'State Serialization',       hint: 'resumable iterator, length-prefix bytes, BACKUP/RESTORE re-anchoring' },
      { href: '/concepts/ood',                   title: 'OOD Principles',            hint: 'SOLID, 5C method, design patterns' },
      { href: '/concepts/system-design',         title: 'System Design Basics',      hint: '4S, QPS, cache, sharding' },
    ],
  },
];

const seen = new Set();
const allItems = sections
  .flatMap(s => s.items)
  .filter(item => {
    if (seen.has(item.href)) return false;
    seen.add(item.href);
    return true;
  })
  .sort((a, b) => a.title.localeCompare(b.title));

const totalConcepts = allItems.length;
---
<Layout title="interview cheat sheet" showHome={false}>

  <div class="view-toggle" role="tablist">
    <button data-view="debug" class="active" type="button">🐛 Debugging</button>
    <button data-view="general" type="button">⚙️ General Coding</button>
  </div>

  <!-- ════════════════ DEBUG VIEW (default) ════════════════ -->
  <div id="view-debug">
    <h1>Python Debugging — Assessment 2</h1>
    <p style="color: var(--muted); margin-top: -2px;">
      60-min CodeSignal: you get a broken codebase + a failing <code>unittest</code>
      suite, and fix the <strong>root cause</strong> of each failure until the tests
      pass. No AI, proctored. This is the whole playbook — read top to bottom once,
      then drill the mocks.
    </p>

    <div class="dbg-box">
      <h2>The format — what you're walking into</h2>
      <ul class="tight">
        <li><strong>Existing code, failing tests.</strong> You read & fix; you don't write from scratch.</li>
        <li><strong>The test suite IS the spec.</strong> "In case of ambiguity, use the test suite as the final word." If no test checks an edge case, it's <em>not</em> a bug — leave it.</li>
        <li><strong>Run tests early and often.</strong> Re-run after every fix.</li>
        <li><strong>Finishing early = bonus.</strong> You do <em>not</em> need every test green to advance — bank the easy ones, don't tunnel on one hard bug.</li>
        <li><strong>Tools:</strong> <code>print()</code> works; <code>pdb</code>/<code>pdb++</code> is faster. The in-browser graphical debugger is buggy — don't use it.</li>
      </ul>
    </div>

    <div class="section">
      <h2>The one habit — predict → check</h2>
      <p>Debugging isn't cleverness. It's one repeated move:</p>
      <blockquote>Before you run a line, <strong>say what you expect</strong> ("this appends, so
      <code>flat</code> should grow"). Run it. <strong>Check.</strong> Match → keep going.
      <strong>Mismatch → that line is your bug.</strong></blockquote>
      <p>The bug is the first place the program stops agreeing with you. pdb is just how you
      walk the program forward and check.</p>
    </div>

    <div class="section">
      <h2>The 5-move loop (every bug, same loop)</h2>
      <ol class="loop">
        <li><strong>Read the traceback.</strong> It names the failing line + the symptom.
          Form a hypothesis: "<code>idx</code> is a tuple → it came from <code>passing_indices</code> → the bug's in there."</li>
        <li><strong><code>b file.py:&lt;first line of that function&gt;</code> then <code>c</code>.</strong>
          Freeze at the start of the suspect function.</li>
        <li><strong><code>cl</code> the breakpoint</strong> → now you have manual control (essential before stepping over a recursive call, or it re-fires).</li>
        <li><strong><code>a</code> and <code>ll</code></strong> — see the inputs and the code. Then
          <strong><code>n</code> down the function</strong>, and after each line <strong><code>p</code> the variable</strong> and check your prediction.</li>
        <li><strong>First mismatch = the bug.</strong> If the mismatching line is a function call,
          <strong><code>s</code> into it</strong> and repeat one level deeper.</li>
      </ol>
    </div>

    <div class="section">
      <h2>pdb — the ten commands that matter</h2>
      <table class="dbg-table">
        <thead><tr><th>cmd</th><th>does</th><th>you reach for it when…</th></tr></thead>
        <tbody>
          <tr><td><code>l</code> / <code>ll</code></td><td>list 11 lines / the whole function</td><td>"where am I in the code"</td></tr>
          <tr><td><code>w</code></td><td>print the call stack</td><td>"how did I get here" — esp. recursion</td></tr>
          <tr><td><code>a</code></td><td>print the current function's args</td><td>first thing after a breakpoint hits</td></tr>
          <tr><td><code>p</code> / <code>pp</code></td><td>print / pretty-print any expression</td><td>inspect a var — <em>or evaluate a call</em>: <code>p np.sum(x,axis=1)</code></td></tr>
          <tr><td><code>n</code></td><td>run line, <strong>step over</strong> calls</td><td>walk down a function</td></tr>
          <tr><td><code>s</code></td><td>run line, <strong>step into</strong> calls</td><td>descend into a suspect function</td></tr>
          <tr><td><code>r</code></td><td>run until this function returns — <strong>shows the return value</strong></td><td>"what does this actually return"</td></tr>
          <tr><td><code>c</code></td><td>continue to next breakpoint</td><td>skip ahead</td></tr>
          <tr><td><code>b file:line</code></td><td>set a breakpoint</td><td>stop exactly where you suspect</td></tr>
          <tr><td><code>cl N</code></td><td>clear breakpoint N</td><td>stop it re-firing (loops / recursion)</td></tr>
          <tr><td><code>u</code> / <code>d</code></td><td>move up / down a stack frame</td><td>inspect the <em>caller's</em> variables</td></tr>
        </tbody>
      </table>
      <p class="dbg-sub"><strong>3 ways into pdb:</strong>
        <code>python -m pdb -m unittest test_x</code> (start under pdb) ·
        <code>breakpoint()</code> in the code (opens pdb there) ·
        post-mortem after a crash: <code>import pdb; pdb.pm()</code>.</p>
    </div>

    <div class="section">
      <h2>Symptom → suspect — the fast-triage table</h2>
      <p style="color: var(--muted); margin: -2px 0 6px; font-size: 0.85rem;">
        the failure message usually <em>is</em> the diagnosis. Learn to read it.</p>
      <table class="dbg-table">
        <thead><tr><th>you see…</th><th>look for…</th></tr></thead>
        <tbody>
          <tr><td><code>nan</code> / <code>inf</code> in the output</td><td>numerical overflow — <strong>subtract the max before <code>np.exp</code></strong> (stable softmax / log-sum-exp)</td></tr>
          <tr><td><code>ValueError: could not be broadcast … (2,3) (2,)</code></td><td>shape mismatch — a missing <code>keepdims=True</code>, or need <code>x[:, None]</code> to add an axis</td></tr>
          <tr><td><code>ValueError: truth value of an array … is ambiguous</code></td><td>Python <code>and</code>/<code>or</code>/<code>not</code> used on a boolean <em>array</em> — use bitwise <code>&amp;</code>/<code>|</code>/<code>~</code>, with parens: <code>(a&gt;0) &amp; (b&gt;0)</code></td></tr>
          <tr><td><code>'tuple' object has no attribute 'ndim'</code></td><td><code>np.where(cond)</code> / <code>np.nonzero()</code> with one arg returns a <strong>tuple</strong> — index <code>[0]</code></td></tr>
          <tr><td>result has the right values in the <strong>wrong places</strong></td><td><code>np.where(cond, a, b)</code> — the two branches are swapped</td></tr>
          <tr><td>array has right values, <strong>wrong shape</strong></td><td>wrong <code>axis=</code> on <code>sum</code>/<code>min</code>/<code>max</code>, or wrong <code>k=</code> on <code>triu</code>/<code>tril</code></td></tr>
          <tr><td>passes <strong>alone</strong>, fails <strong>in the suite</strong></td><td>shared mutable state — mutable default arg, or a class-level <code>[]</code>/<code>{}</code></td></tr>
          <tr><td>output length off by exactly 1</td><td>recursion base case (<code>&gt;</code> vs <code>&gt;=</code>) or a loop <code>range()</code> off-by-one</td></tr>
          <tr><td><code>KeyError</code></td><td><code>d[k]</code> should be <code>d.get(k, default)</code> — the spec names the default</td></tr>
          <tr><td>every random draw identical / not reproducible</td><td>global <code>np.random</code> instead of an instance <code>RandomState</code>, or re-seeding inside a hot path</td></tr>
          <tr><td>a metric is an integer when it should be fractional</td><td><code>//</code> floor division where <code>/</code> was meant</td></tr>
          <tr><td>a probability array doesn't sum to 1</td><td>missing renormalization (<code>x / x.sum()</code>) after a filter/zeroing step</td></tr>
        </tbody>
      </table>
    </div>

    <div class="section">
      <h2>Bug archetypes — recognize on sight</h2>
      <h3>NumPy</h3>
      <pre><code>np.bincount(x)              # length = x.max()+1 — too short. Fix: minlength=V
np.where(cond)             # returns a TUPLE of index arrays — index [0]
np.where(cond, a, b)       # 3-arg = elementwise select. Don't swap a/b.
np.nonzero(arr)            # also a tuple, length = arr.ndim
a - b   # a:(n,)  b:(n,1)  # silently broadcasts to (n,n) — no error!
np.sum(x, axis=?)          # axis=0 down columns, axis=1 across rows
np.sum(x, axis=-1)         # …drop the axis → divide won't broadcast. keepdims=True
np.exp(x)                  # OVERFLOWS for large x → nan. exp(x - x.max())
np.max(probs)              # the VALUE; greedy decode wants np.argmax (the index)
np.random.seed(s)          # mutates GLOBAL rng. Use rng = np.random.RandomState(s)
np.argsort(x)[:k]          # the k LOWEST. Top-k is [-k:]
(a&gt;0) and (b&gt;0)          # ValueError on arrays! bitwise: (a&gt;0) &amp; (b&gt;0)  ←parens</code></pre>
      <h3>Broadcasting — divide rows vs. columns by a vector</h3>
      <p class="dbg-sub">The single most common broadcasting fix. Memorize which one needs the reshape.</p>
      <pre><code>m = np.array([[10,10],[20,20],[30,30]])   # shape (3, 2)

# DIVIDE EACH ROW i by v[i]  →  v must become a COLUMN (N,1)
v = np.array([2,4,6])                      # (3,) — one per row
m / v[:, None]          # ✓   also: v[:, np.newaxis] · v.reshape(-1,1)
m / v                   # ✗   ValueError: (3,2) vs (3,)

# DIVIDE EACH COLUMN j by v[j]  →  v stays 1-D (N,), broadcasts as-is
v = np.array([10,20])                      # (2,) — one per column
m / v                   # ✓   no reshape needed</code></pre>
      <table class="dbg-table">
        <thead><tr><th>goal</th><th>vector length</th><th>vector shape needed</th></tr></thead>
        <tbody>
          <tr><td>divide each <strong>row</strong> by <code>v[i]</code></td><td>= num rows</td><td>must be 2-D <code>(N,1)</code> → <code>v[:, None]</code></td></tr>
          <tr><td>divide each <strong>column</strong> by <code>v[j]</code></td><td>= num cols</td><td>1-D <code>(N,)</code> is fine — broadcasts as-is</td></tr>
        </tbody>
      </table>
      <p class="dbg-sub"><strong>Rule:</strong> a vector broadcasts against the matrix's
        <em>trailing</em> axis. Columns already line up <code>(N,)</code>; rows need an explicit
        column shape <code>(N,1)</code>. This is the same fix as <code>keepdims=True</code> after a
        row-wise <code>sum</code> — and exactly the bug in mock-5's <code>normalize_rows</code>.</p>
      <h3>The two meanings of <code>None</code> in NumPy</h3>
      <pre><code>arr = np.array([[1,2],[3,4]])

# (1) axis=None in a REDUCTION → collapse everything to a scalar
np.sum(arr, axis=None)     # 10     (axis=None is the default)
np.sum(arr, axis=0)        # [4,6]  — down columns
np.sum(arr, axis=1)        # [3,7]  — across rows

# (2) None as an INDEX → alias for np.newaxis: inserts a size-1 axis
a = np.array([1,2,3])      # shape (3,)
a[:, None]                 # shape (3,1) — a COLUMN vector
a[None, :]                 # shape (1,3) — a ROW vector</code></pre>
      <p class="dbg-sub"><strong>Don't confuse them:</strong> <code>axis=None</code>
        <em>removes</em> dimensions (reduce over the flattened array); <code>x[..., None]</code>
        <em>adds</em> one. The index form is your broadcasting tool — it's how you turn a
        <code>(N,)</code> vector into the <code>(N,1)</code> column from the rule above.</p>
      <h3>Pure Python</h3>
      <pre><code>def f(x, acc=[]):          # mutable default — shared across ALL calls
class C: log = []          # class attribute — shared across ALL instances
def rec(...): rec(sub)     # recursion: return value DISCARDED — need return/extend
if n &gt; limit: ...          # recursion base case off-by-one — &gt; vs &gt;=
for i in range(len(a)-2)   # loop-range off-by-one — misses the last pair
class P(NamedTuple): y;x   # field ORDER — positional construction silently swaps
[f(i) for i in xs]         # late-binding closure: lambdas capture the FINAL i
[d[c] for c in s]          # KeyError on miss — want [d.get(c, default) ...]
total // count             # int division where you wanted /</code></pre>
    </div>

    <div class="section">
      <h2>Required topics — the email's checklist</h2>
      <p><strong>Python:</strong> classes &amp; methods · list comprehensions · recursion ·
        <code>typing.NamedTuple</code> (the email says "<code>collections.NamedTuple</code>" — no
        such thing; it means the <code>typing</code> class) · <code>unittest</code>.</p>
      <p><strong>NumPy:</strong> <code>np.array</code> · <code>np.min</code>/<code>np.max</code> ·
        <code>np.sum</code> · <code>np.bincount</code> · <code>np.nonzero</code> ·
        <code>np.where</code> · <code>np.random.RandomState</code> · <strong>broadcasting</strong> ·
        floating-point numbers.</p>
      <p style="color: var(--muted); font-size: 0.85rem;">Every mock below exercises these.
        Note the list is about <em>primitives</em> — the skill is the same whatever domain
        the codebase dresses itself in.</p>
    </div>

    <div class="section problems-section">
      <h2>Practice — the 6-mock difficulty ladder</h2>
      <p style="color: var(--muted); margin: -2px 0 6px; font-size: 0.85rem;">
        each = a buggy module + a failing <code>test_*.py</code> + an <code>ANSWERS.md</code>.
        Fix the module, not the tests. <code>git checkout</code> to reset and re-drill.
      </p>
      <div class="problems-subhead">onboarding — learn pdb + the predict→check loop</div>
      <ul class="problems-grid">
        {debugMocks.filter(m => m.tier === 'onboarding').map(m => (
          <li>
            <a href={`${GH_DEBUG}/${m.dir}`} target="_blank" rel="noopener" class="chip">
              <span class="chip-num">{m.num}</span>
              <span class="chip-title">{m.title}</span>
              <span class="chip-tag">{m.bugs} bugs · {m.tag}</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="problems-subhead">interview-realistic — LLM codebases, harder + interacting bugs</div>
      <ul class="problems-grid">
        {debugMocks.filter(m => m.tier !== 'onboarding').map(m => (
          <li>
            <a href={`${GH_DEBUG}/${m.dir}`} target="_blank" rel="noopener" class="chip chip-six">
              <span class="chip-num">{m.num}</span>
              <span class="chip-title">{m.title}</span>
              <span class="chip-tag">{m.bugs} bugs · {m.tag}</span>
            </a>
          </li>
        ))}
      </ul>
      <p class="dbg-sub">
        <strong>How to drill:</strong> read the test file first (it's the spec) → run the suite,
        read every failure → fix root causes → re-run → check <code>ANSWERS.md</code>.
        Set a real 60-min timer on mocks 4–6. Full notes &amp; research:
        <a href="https://github.com/vyvy3n/interview/tree/main/practice-python-debugging" target="_blank" rel="noopener">practice-python-debugging/</a>.
      </p>
    </div>

    <div class="section">
      <h2>Last-5-minutes reminders</h2>
      <ul class="tight">
        <li>The <strong>test suite is the spec</strong> — don't fix what isn't tested.</li>
        <li><strong>Bank the easy bugs first.</strong> A bug you can't crack fast: skip it, come back. You don't need 100%.</li>
        <li>Debug <strong>bottom-up</strong> — fix the leaf helper before the function that calls it.</li>
        <li><code>nan</code> → subtract the max. Shape error → <code>keepdims</code> / <code>[:,None]</code>.
          Tuple-has-no-attribute → <code>[0]</code>. Passes-alone-fails-in-suite → shared mutable state.</li>
        <li>A test <em>passing</em> doesn't mean the function is correct — it means <em>that input</em> is. Trust the failing test.</li>
      </ul>
    </div>
  </div>

  <!-- ════════════════ GENERAL VIEW ════════════════ -->
