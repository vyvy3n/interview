---
import Layout from '../layouts/Layout.astro';
import { Code } from 'astro:components';

const GH = 'https://github.com/vyvy3n/interview/blob/main/practice-general-coding-ability';
const GH_DEBUG = 'https://github.com/vyvy3n/interview/tree/main/practice-python-debugging';

// ── Debug-view code snippets — rendered syntax-highlighted via <Code> ──
const numpyArchetypes = `np.bincount(x)             # length = x.max()+1 — too short. Fix: minlength=V
np.where(cond)             # returns a TUPLE of index arrays — index [0]
np.where(cond, a, b)       # 3-arg = elementwise select. Don't swap a/b.
np.nonzero(arr)            # also a tuple, length = arr.ndim
a - b   # a:(n,)  b:(n,1)  # silently broadcasts to (n,n) — no error!
np.sum(x, axis=?)          # axis=0 down columns, axis=1 across rows
np.sum(x, axis=-1)         # drops the axis -> divide won't broadcast. keepdims=True
np.exp(x)                  # OVERFLOWS for large x -> nan. exp(x - x.max())
np.max(probs)              # the VALUE; greedy decode wants np.argmax (the index)
np.random.seed(s)          # mutates GLOBAL rng. Use rng = np.random.RandomState(s)
np.argsort(x)[:k]          # the k LOWEST. Top-k is [-k:]
(a > 0) and (b > 0)        # ValueError on arrays! bitwise: (a > 0) & (b > 0)  <- parens`;

const bincountSnippet = `ids = vocab.encode(document)         # 1-D int array of token ids

# BUG: bincount output length is max(ids)+1 — NOT the vocab size.
# If the highest-id token never appears, the array is too SHORT.
np.bincount(ids)                     # length 7 when the vocab has 10 tokens

# FIX: minlength pads the output up to the vocab size
np.bincount(ids, minlength=len(vocab.tokens))

# minlength only EXTENDS, never truncates. If an id can be >= V, the
# output is too LONG — and the real bug is upstream, in encode().

# Alternative — pre-allocate, so the length is correct by construction:
counts = np.zeros(len(vocab.tokens), dtype=int)
np.add.at(counts, ids, 1)            # for each index i in ids: counts[i] += 1, in place`;

const broadcastSnippet = `m = np.array([[10, 10], [20, 20], [30, 30]])   # shape (3, 2)

# DIVIDE EACH ROW i by v[i]  ->  v must become a COLUMN (N, 1)
v = np.array([2, 4, 6])                        # (3,) — one per row
m / v[:, None]          # OK    also: v[:, np.newaxis] · v.reshape(-1, 1)
m / v                   # ERR   ValueError: (3,2) vs (3,)

# DIVIDE EACH COLUMN j by v[j]  ->  v stays 1-D (N,), broadcasts as-is
v = np.array([10, 20])                         # (2,) — one per column
m / v                   # OK    no reshape needed`;

const whereSnippet = `arr = np.array([1, 10, 5, 20])

# 3 ARGS  ->  vectorized if-else: value from x where cond, else from y
np.where(arr > 8, 100, arr)    # [1, 100, 5, 100]   (same shape as input)

# 1 ARG   ->  returns a TUPLE of index arrays where cond is True
np.where(arr > 8)              # (array([1, 3]),)   <- a tuple!
np.where(arr > 8)[0]           # array([1, 3])      <- the indices

# real use: token ids above a threshold, then ranked by count
def high_frequency_ids(counts, threshold):
    indices = np.where(counts > threshold)[0]    # 1-arg -> add [0]
    return sorted(indices, key=lambda i: -counts[i])`;

const noneSnippet = `arr = np.array([[1, 2], [3, 4]])

# (1) axis=None in a REDUCTION  ->  collapse everything to a scalar
np.sum(arr, axis=None)     # 10     (axis=None is the default)
np.sum(arr, axis=0)        # [4, 6]  — down columns
np.sum(arr, axis=1)        # [3, 7]  — across rows

# (2) None as an INDEX  ->  alias for np.newaxis: inserts a size-1 axis
a = np.array([1, 2, 3])    # shape (3,)
a[:, None]                 # shape (3, 1) — a COLUMN vector
a[None, :]                 # shape (1, 3) — a ROW vector`;

const paddingMaskAttentionSnippet = `# From test_attention.TestApplyPaddingMask (batch 0 walkthrough)
scores = np.ones((2, 3, 3))
pad_mask = np.array([[True, True, False], [True, False, False]])
# pad_mask[0] = positions 0,1 real; position 2 padding -> mask KEY j=2 for ALL queries i

# BUG: pad_mask[:, :, None] has shape (2, 3, 1). Broadcast with scores (2, 3, 3) means
#      each cell scores[b, i, j] uses cond = pad_mask[b, i]  — QUERY index i, not KEY j.
np.where(pad_mask[:, :, None], scores, -np.inf)

# FIX: put the size-1 axis on QUERY so the same pad_mask[b, j] applies to every query i
np.where(pad_mask[:, None, :], scores, -np.inf)`;

const pythonArchetypes = `def f(x, acc=[]):          # mutable default — shared across ALL calls
class C: log = []          # class attribute — shared across ALL instances
def rec(...): rec(sub)     # recursion: return value DISCARDED — need return/extend
if n > limit: ...          # recursion base case off-by-one — > vs >=
for i in range(len(a)-2)   # loop-range off-by-one — misses the last pair
class P(NamedTuple): y; x  # field ORDER — positional construction silently swaps
[f(i) for i in xs]         # late-binding closure: lambdas capture the FINAL i
[d[c] for c in s]          # KeyError on miss — want [d.get(c, default) ...]
total // count             # int division where you wanted /`;

const recursionSnippet = `# BUG 1 — the recursive call's return value is DISCARDED
def flatten(xs):
    out = []
    for x in xs:
        if isinstance(x, list):
            flatten(x)            # <- result thrown away; nested items vanish
        else:
            out.append(x)
    return out
# FIX: out.extend(flatten(x))    # capture + merge the return value

# BUG 2 — base case off-by-one: > vs >=
def gen(seq, max_len):
    if len(seq) > max_len:        # <- stops one step late -> length max_len+1
        return seq
    ...                          # FIX: >=

# WHY it's subtle: every call has its OWN locals. The recursive call's
# 'out' is a DIFFERENT list — its work only comes back through 'return'.`;

const slicingSnippet = `xs = ["a", "b", "c"]      # len 3
xs[3]                     # IndexError
xs[3:]                    # []           slices CLAMP — never raise
xs[1:99]                  # ['b', 'c']   stop clamped to len

# so tokens[i+2:] is "the tail, or [] if past the end" —
# no  if i+2 < len(tokens)  guard needed`;

const namedtupleSnippet = `from typing import NamedTuple

class Config(NamedTuple):
    num_classes: int
    num_samples: int
    seed: int

# BUG — positional construction with args in the wrong order.
# No error: all three are ints, so the swap is SILENT.
Config(num_samples, num_classes, seed)        # first two swapped!
# FIX — construct by KEYWORD:
Config(num_classes=nc, num_samples=ns, seed=s)

# other NamedTuple traps:
#   - a field with a default must come AFTER all non-default fields
#   - "subclassing to add a field" does NOT extend the tuple layout`;

const mutableDefaultSnippet = `# BAD — seen=[] is built ONCE at def-time; every call shares that one list
def merge_vocabs(vocab_lists, seen=[]):
    for toks in vocab_lists:
        for t in toks:
            if t not in seen:
                seen.append(t)
    return seen

merge_vocabs([["x", "y"]])   # ['x', 'y']
merge_vocabs([["p", "q"]])   # ['x', 'y', 'p', 'q']  <- leaked from call 1!

# GOOD — default None, build a fresh list inside the body
def merge_vocabs(vocab_lists, seen=None):
    if seen is None:
        seen = []
    ...  # same body`;

const oovSnippet = `merged = apply_merges(list(text), merges)   # items are still STRINGS

# BUG — direct indexing: KeyError on any token never seen in the vocab
ids = [vocab.token_to_id[tok] for tok in merged]

# FIX — safe lookup: unknowns map to unk_id (when the spec says so)
ids = [vocab.token_to_id.get(tok, vocab.unk_id) for tok in merged]

# pdb: which pieces are OOV?
[t for t in merged if t not in vocab.token_to_id]`;

const sortingSnippet = `sorted(xs)                          # ascending — returns a NEW list
sorted(xs, reverse=True)            # descending
xs.sort()                           # in-place — returns None!

# key= : sort by a derived value
sorted(words, key=len)              # by length
sorted(pairs, key=lambda p: p[1])   # by the 2nd element of each pair
sorted(items, key=lambda x: x.score)

# descending by a numeric key — negate it
sorted(indices, key=lambda i: -counts[i])      # highest count first
sorted(items, key=lambda x: -x.score)

# multi-key — a tuple sorts left-to-right
sorted(items, key=lambda x: (x.group, -x.score))   # group asc, then score desc`;

const floatNanSnippet = `np.log(0.0)                # -inf    (a 0 probability -> -inf logprob)
np.log(-1.0)               # nan     (log of a negative)
# fix: floor first -> np.log(np.clip(p, 1e-12, None))

nan = float("nan")
nan == nan                 # False!  nan compares unequal to everything
np.max([1.0, nan])         # nan     one nan poisons the whole reduction
# fix: np.isnan(x) to test;  np.nanmax / np.nansum to ignore nans

0.1 + 0.2 == 0.3           # False   never use == on floats
# fix: math.isclose(a, b)  or  np.isclose(a, b)  /  np.allclose`;

const viewCopySnippet = `a = np.arange(6)

v = a[2:5]                 # a SLICE is a VIEW — shares memory with a
v[0] = 99                  # ...this ALSO changes a[2]!

c = a[a > 2]               # fancy / boolean indexing is a COPY
c[0] = 99                  # ...a is untouched

# fix: a[2:5].copy() when you need an independent array`;

const maxMaximumSnippet = `np.max(a)                  # REDUCTION   -> a scalar (the largest element)
np.maximum(a, b)           # ELEMENTWISE -> an array  (pairwise max of a, b)
np.maximum(a, 1e-6)        # elementwise FLOOR — clamp every element up to 1e-6

# np.max(a, 1e-6) is a bug: 1e-6 is read as the 'axis' arg -> TypeError
# same trap: np.min vs np.minimum`;

