---
import Layout from '../layouts/Layout.astro';

// Categorized concepts — tap to drill in.
const sections = [
  {
    title: 'Source Notes',
    note: 'full content from your study docs (with diagrams)',
    items: [
      { href: '/notes/cheatsheet',     title: 'Cheatsheet',          hint: '核心模板: heapify, union find, trie, partition…' },
      { href: '/notes/high-frequency', title: 'Leetcode 高频题',     hint: '面试高频题, BFS / DFS / D&C / 哈希' },
      { href: '/notes/dp',             title: 'Dynamic Programming', hint: '最值 / 计数 / 存在型 DP, 滚动数组' },
      { href: '/notes/leetcode',       title: 'Leetcode (主笔记)',   hint: '主线笔记 + 解法' },
      { href: '/notes/segment-tree',   title: 'Segment Tree',        hint: '建树 / 查询 / 更新 / lazy' },
      { href: '/notes/ood',            title: 'Object-Oriented Design', hint: 'SOLID, 5C, UML, 经典设计题' },
      { href: '/notes/system-design',  title: 'System Design',       hint: 'scale, sharding, caching' },
      { href: '/notes/ml',             title: 'ML Interview',        hint: '基础概念 + 常考题' },
      { href: '/notes/interview-logs', title: '面试笔记 & Logs',     hint: '问题记录 / 复盘' },
    ],
  },
  {
    title: 'Patterns',
    note: 'pattern-first quick reference for problem recognition',
    items: [
      { href: '/concepts/two-pointers', title: 'Two Pointers', hint: 'opposite ends, fast/slow, partitioning' },
      { href: '/concepts/sliding-window', title: 'Sliding Window', hint: 'fixed/variable subarray under invariant' },
      { href: '/concepts/binary-search', title: 'Binary Search', hint: 'sorted array or monotonic predicate' },
      { href: '/concepts/prefix-sum', title: 'Prefix Sum', hint: 'range sums, subarray-sum-equals-K' },
      { href: '/concepts/dfs-backtracking', title: 'DFS & Backtracking', hint: 'enumerate, prune, undo' },
      { href: '/concepts/bfs', title: 'BFS', hint: 'layered, implicit graph, bidirectional' },
      { href: '/concepts/tree-divide-conquer', title: 'Tree Divide & Conquer', hint: 'return-from-children pattern' },
      { href: '/concepts/topo-sort', title: 'Topological Sort', hint: 'DAG order, indegree BFS or DFS' },
      { href: '/concepts/union-find', title: 'Union Find', hint: 'connected components, path compression' },
      { href: '/concepts/heap', title: 'Heap & Top-K', hint: 'heapify O(n), kth element, streaming' },
      { href: '/concepts/greedy', title: 'Greedy', hint: 'local choice → global optimum, intervals' },
    ],
  },
  {
    title: 'Data Structures',
    items: [
      { href: '/concepts/hash-table', title: 'Hash Table Tricks', hint: 'count, prefix-hash, two-sum family' },
      { href: '/concepts/trie', title: 'Trie / Prefix Tree', hint: 'word search, prefix queries' },
      { href: '/concepts/monotonic-stack', title: 'Monotonic Stack', hint: 'next greater/smaller element' },
      { href: '/concepts/linked-list', title: 'Linked List', hint: 'dummy head, doubly linked, reversal' },
    ],
  },
  {
    title: 'Algorithms / Tricks',
    items: [
      { href: '/concepts/quickselect', title: 'QuickSelect / Partition', hint: 'kth largest in O(n) avg' },
      { href: '/concepts/big-int-strings', title: 'Big-Int String Math', hint: 'add/subtract/multiply long numbers' },
      { href: '/concepts/fast-power', title: 'Fast Power', hint: 'a^n mod m in O(log n)' },
    ],
  },
  {
    title: 'Design',
    items: [
      { href: '/concepts/lru-cache', title: 'LRU Cache', hint: 'hash + doubly linked list' },
      { href: '/concepts/bst-iterator', title: 'BST Iterator', hint: 'in-order traversal, controlled stack' },
    ],
  },
];
---
<Layout title="interview cheat sheet" showHome={false}>
  <h1>cheat sheet</h1>
  <p style="color: var(--muted); margin-top: -4px;">quick review for coding interviews — tap a topic.</p>

  {sections.map(section => (
    <div class="section">
      <h2>{section.title}</h2>
      {section.note && <p style="color: var(--muted); margin: -2px 0 6px; font-size: 0.85rem;">{section.note}</p>}
      <ul class="concepts">
        {section.items.map(item => (
          <li>
            <a href={item.href}>
              {item.title}
              <small>{item.hint}</small>
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</Layout>
